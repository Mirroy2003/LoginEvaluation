@{
    Layout = "~/Views/Shared/_LoginLayout.cshtml";
    ViewData["Title"] = "Cuenta activada";
    ViewData["BodyClass"] = "welcome-page";
}

@section Styles {
    <link rel="stylesheet" href="~/css/welcome.css" asp-append-version="true" />
}

<div class="welcome-layout">
    <div class="welcome-topbar">
        <div class="welcome-help" title="Ayuda">?</div>
    </div>

    <div class="welcome-shell welcome-illustration">
        <div class="welcome-card">
            <div class="welcome-icon">🚀</div>
            <div class="welcome-title">¡Bienvenido, Luis!</div>
            <div class="welcome-text">
                Su cuenta en LoginBusiness está activada.<br />
                Ya puede iniciar sesión.
            </div>
            <a class="btn btn-primary w-100" asp-controller="Account" asp-action="Login">Iniciar sesión</a>
        </div>

        <div class="welcome-institution">
            <div class="block">Logo</div>
            <div class="block">PCM</div>
            <div class="block">CND</div>
        </div>
    </div>
</div>
