@model LoginEvaluation.Web.ViewModels.LoginViewModel
@{
    Layout = "~/Views/Shared/_LoginLayout.cshtml";
    ViewData["Title"] = "Login";
    ViewData["BodyClass"] = "login-page";
    var sessionExpired = Context.Request.Query.ContainsKey("expired");
}

@section Styles {
    <link rel="stylesheet" href="~/css/login.css" asp-append-version="true" />
}

<div class="login-topbar"></div>
<div class="login-shell login-illustration">
    <a href="#" class="login-help" title="Ayuda">?</a>
    <div class="login-stack">
        <div class="login-card">
            <div class="login-tabs mb-3">
                <label class="login-tab @(Model.DocumentType == "DNI" ? "active" : "")">
                    <input asp-for="DocumentType" type="radio" value="DNI" class="d-none" /> DNI
                </label>
                <label class="login-tab @(Model.DocumentType == "CE" ? "active" : "")">
                    <input asp-for="DocumentType" type="radio" value="CE" class="d-none" /> CE
                </label>
            </div>

            <form asp-action="Login" method="post" class="login-form">
                <div asp-validation-summary="ModelOnly" class="login-errors"></div>

                <div>
                    <div class="login-label">DNI</div>
                    <div class="login-input-group">
                        <span class="login-input-icon">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M12 12c2.761 0 5-2.239 5-5s-2.239-5-5-5-5 2.239-5 5 2.239 5 5 5Zm0 2c-3.33 0-10 1.667-10 5v1h20v-1c0-3.333-6.67-5-10-5Z" fill="#9a9a9a"/></svg>
                        </span>
                        <input asp-for="Dni" placeholder="Ingresa tu DNI" />
                    </div>
                    <span asp-validation-for="Dni" class="login-errors"></span>
                </div>

                <div>
                    <div class="login-label">Contraseña</div>
                    <div class="login-input-group">
                        <span class="login-input-icon">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M17 9h-1V7a4 4 0 0 0-8 0v2H7a1 1 0 0 0-1 1v10a1 1 0 0 0 1 1h10a1 1 0 0 0 1-1V10a1 1 0 0 0-1-1ZM9 7a3 3 0 1 1 6 0v2H9V7Zm8 12H7v-8h10v8Zm-5-3a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3Z" fill="#9a9a9a"/></svg>
                        </span>
                        <input asp-for="Password" type="password" placeholder="Ingresar contraseña" />
                        <button type="button" class="login-eye" id="toggle-password">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M12 5c-5 0-9 5-9 7s4 7 9 7 9-5 9-7-4-7-9-7Zm0 12c-3.314 0-6-2.686-6-5s2.686-5 6-5 6 2.686 6 5-2.686 5-6 5Zm0-8a3 3 0 1 0 0 6 3 3 0 0 0 0-6Z" fill="#9a9a9a"/></svg>
                        </button>
                    </div>
                    <div class="d-flex justify-content-between align-items-center mt-1">
                        <span asp-validation-for="Password" class="login-errors"></span>
                        <a href="#" class="login-link">¿Olvidó su contraseña?</a>
                    </div>
                </div>

                <button type="submit" class="login-button">Ingresar</button>
            </form>
        </div>

        <div class="login-support">
            <div class="login-support-icon">📞</div>
            <div class="login-support-text">
                ¿Necesita ayuda?, <a href="#">contacte con el área de soporte.</a>
            </div>
        </div>
    </div>

    <div class="login-institution">
        <div class="block">Logo</div>
        <div class="block">PCM</div>
        <div class="block">CND</div>
    </div>
</div>

<div class="session-toast-container">
    <div class="session-toast" id="session-expired-toast" role="alert" aria-live="assertive" aria-atomic="true">
        <div class="body">
            <div class="icon">ℹ️</div>
            <div class="message">Su sesión ha expirado debido a inactividad. Por favor, inicie sesión nuevamente.</div>
        </div>
        <div class="progress-bar"></div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            const expired = @sessionExpired.ToString().ToLowerInvariant();
            if (expired) {
                const toastEl = document.getElementById('session-expired-toast');
                if (toastEl) {
                    toastEl.classList.add('show');
                    setTimeout(() => toastEl.classList.remove('show'), 5000);
                }
            }

            const tabLabels = document.querySelectorAll('.login-tab');
            tabLabels.forEach(label => {
                label.addEventListener('click', () => {
                    tabLabels.forEach(l => l.classList.remove('active'));
                    label.classList.add('active');
                    const input = label.querySelector('input[type="radio"]');
                    if (input) {
                        input.checked = true;
                    }
                });
            });

            const toggleBtn = document.getElementById('toggle-password');
            const pwdInput = document.querySelector('input[name="Password"]');
            if (toggleBtn && pwdInput) {
                toggleBtn.addEventListener('click', () => {
                    const isPassword = pwdInput.getAttribute('type') === 'password';
                    pwdInput.setAttribute('type', isPassword ? 'text' : 'password');
                });
            }
        })();
    </script>
}
